# Cloudflare Pages cache control
# Prevent browser/CDN from caching HTML so new deploys are picked up immediately

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets (JS/CSS) have content-hash filenames — can be cached long-term
/assets/*
  Cache-Control: public, max-age=31536000, immutable
